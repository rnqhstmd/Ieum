# ─── ws-relay 환경변수 예시 ──────────────────────────────────────
# 이 파일을 복사해 .env.local 또는 .env 로 사용하세요.

# WebSocket 서버 포트 (기본값 3001)
PORT=3001

# Admin HTTP 서버 포트. 설정 시 admin 서버 기동. 미설정 시 admin 미기동.
ADMIN_PORT=3002

# PostgreSQL 연결 문자열 (postgres:// 형식).
# 미설정 시 InMemoryOpStore + 멤버십 게이트 off (walking skeleton).
RELAY_DATABASE_URL=

# HMAC 서명 비밀키 (backend·ws-relay 공유, 32바이트 이상 무작위).
# 미설정 시 trust-relay 모드 (인증 검증 off).
AUTH_SECRET=
