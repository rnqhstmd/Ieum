# Spring Boot 백엔드 REST API URL
# 프론트엔드의 fetch 래퍼(src/lib/api.ts)가 이 주소로 요청을 보냅니다.
NEXT_PUBLIC_API_URL=http://localhost:8080

# P5 WebSocket relay 서버 URL (apps/ws-relay, 기본 포트 3001)
# 실시간 협업(src/lib/realtime, useCrdtDocument)에서 사용합니다.
# 주의: NEXT_PUBLIC_ 변수는 빌드 시 클라이언트 번들에 인라인됩니다. 프로덕션/스테이징
# 빌드에서는 반드시 실제 relay 주소로 설정하세요(미설정 시 localhost:3001이 박혀 조용히 실패).
NEXT_PUBLIC_WS_URL=ws://localhost:3001
