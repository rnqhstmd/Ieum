# 이음(Ieum) 환경변수 예시
# 이 파일은 백엔드(Spring Boot, :8080)용입니다.
# 프론트엔드(Next.js)용 변수는 apps/web/.env.local.example 를 참조하세요.

# ─── Database (PostgreSQL, JDBC) ────────────────────────
DATABASE_URL="jdbc:postgresql://localhost:5432/ieum"
DB_USER="postgres"
DB_PASSWORD="postgres"

# ─── Google OAuth (Spring Security) ─────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── WS-AUTH (backend·ws-relay 공유) ────────────────────
# 32바이트 이상 무작위 문자열. 미설정 시 ws-relay는 trust-relay(인증 off) 모드로 동작.
AUTH_SECRET=

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=""
INVITE_FROM_EMAIL="Ieum <noreply@ieum.app>"
